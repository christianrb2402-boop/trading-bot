APP_NAME=multiagent-trading-system
APP_ENV=development
LOG_LEVEL=INFO

SQLITE_PATH=runtime/market_data.db
LOGS_DIR=logs

BINANCE_BASE_URL=https://api.binance.com
BINANCE_TIMEOUT_SECONDS=10
BINANCE_MAX_RETRIES=3
BINANCE_RETRY_DELAY_SECONDS=2

CORE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT
WATCHLIST_SYMBOLS=DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,LTCUSDT,DOTUSDT,MATICUSDT,TRXUSDT,BCHUSDT,NEARUSDT,ARBUSDT,OPUSDT
ENABLE_WATCHLIST=false
MARKET_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

MARKET_TIMEFRAME=1m
MARKET_TIMEFRAMES=1m,3m,5m,15m,30m,1h,4h,1d
EXECUTION_TIMEFRAMES=1m,3m,5m
CONTEXT_TIMEFRAMES=15m,30m,1h
STRUCTURAL_TIMEFRAMES=4h,1d
BINANCE_KLINES_LIMIT=5
BACKTEST_MIN_TRADES=100

DELTA_K_THRESHOLD=0.5
DELTA_WEAK_THRESHOLD_FACTOR=0.1
DELTA_STRONG_THRESHOLD_FACTOR=2.0
DELTA_TEST_WINDOWS=10,20,50
SIGNAL_EVALUATION_WINDOWS=5,10,15
DELTA_OPTIMIZATION_THRESHOLDS=0.5,1.0,1.5,2.0

PAPER_SLIPPAGE_PCT=0.05
PAPER_COMMISSION_PCT=0.1
PAPER_STOP_LOSS_PCT=0.5
PAPER_TAKE_PROFIT_PCT=1.0
PAPER_POLL_SECONDS=5

CONTINUOUS_LOOP_SECONDS=60
SIMULATED_TRADE_EXIT_CANDLES=5
SIMULATED_INITIAL_CAPITAL=1000
SIMULATED_POSITION_SIZE_USD=100

# These percentage-like values accept either fractional notation or percentage-point notation.
# Example: 0.001 = 0.1%, and 0.1 is also interpreted as 0.1%.
SIMULATED_FEE_PCT=0.1
SIMULATED_MAKER_FEE_PCT=0.1
SIMULATED_TAKER_FEE_PCT=0.1
SIMULATED_SLIPPAGE_PCT=0.05
SIMULATED_SPREAD_PCT=0.02
SIMULATED_STOP_LOSS_PCT=0.5
SIMULATED_TAKE_PROFIT_PCT=1.0
SIMULATED_MAX_HOLD_CANDLES=15

SIMULATED_MARKET_TYPE=SPOT
SIMULATED_DEFAULT_LEVERAGE=1
SIMULATED_MAX_LEVERAGE=3
SIMULATED_FUNDING_RATE_ESTIMATE=0.0

MAX_POSITION_PCT_OF_CAPITAL=0.1
MAX_OPEN_POSITIONS=5
MAX_DAILY_SIMULATED_LOSS_PCT=0.03

MIN_REWARD_RISK_RATIO=1.5
MIN_NET_REWARD_RISK_RATIO=1.5
MIN_EXPECTED_NET_EDGE_PCT=0.10
MIN_COST_COVERAGE_MULTIPLE=2.2
MAX_COST_DRAG_PCT=0.35

ALLOW_WEAK_SIGNALS=true
ALLOW_MEDIUM_SIGNALS=true
ALLOW_STRONG_SIGNALS=true
AGGRESSIVENESS_LEVEL=BALANCED
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_CONSECUTIVE_LOSSES=5
MAX_POSITION_SIZE_PCT=0.1
MAX_SYMBOL_EXPOSURE_PCT=0.25
MAX_STRATEGY_EXPOSURE_PCT=0.35
MIN_COST_COVERAGE_MULTIPLE_CONSERVATIVE=3.0
MIN_COST_COVERAGE_MULTIPLE_BALANCED=2.5
MIN_COST_COVERAGE_MULTIPLE_AGGRESSIVE=2.0
PAPER_MODE_AUTO=true
EXPLORATION_MAX_TRADES_PER_HOUR=3
EXPLORATION_MAX_OPEN_POSITIONS=1
EXPLORATION_RISK_PER_TRADE_PCT=0.10
EXPLORATION_MAX_DAILY_DRAWDOWN_PCT=1.00
EXPLORATION_MIN_RR=1.10
SELECTIVE_MIN_RR=1.50
EXPLORATION_MIN_COST_COVERAGE_MULTIPLE=1.10
SELECTIVE_MIN_COST_COVERAGE_MULTIPLE=1.50
PAPER_EXPLORATION_MIN_COST_COVERAGE=1.35
PAPER_SELECTIVE_MIN_COST_COVERAGE=2.20
PAPER_EXPLORATION_MIN_RR=1.05
PAPER_SELECTIVE_MIN_RR=1.35
PAPER_EXPLORATION_BASE_WIN_PROBABILITY=0.53
PAPER_SELECTIVE_BASE_WIN_PROBABILITY=0.58
MIN_SAMPLE_SIZE_FOR_PROFITABILITY_CLAIM=30
BRAIN_MIN_FINAL_SCORE=0.55
AUTONOMOUS_LOOP_SECONDS=60
MARKET_WATCH_LOOP_SECONDS=60
FEATURE_STORE_LOOKBACK=60

PERFORMANCE_LEARNING_MIN_SAMPLE=10
NEWS_ENABLED=true
SENTIMENT_ENABLED=true
CRYPTOPANIC_TOKEN=
COINDESK_RSS_URL=https://www.coindesk.com/arc/outboundfeeds/rss/
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc?query=cryptocurrency%20OR%20bitcoin%20OR%20ethereum&mode=ArtList&maxrecords=10&format=json
ALTERNATIVE_ME_FNG_URL=https://api.alternative.me/fng/?limit=1&format=json
